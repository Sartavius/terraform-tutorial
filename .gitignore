# Terraform state files (managed remotely via S3)
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform plan output
tfplan
*.tfplan

# Terraform variable overrides (may contain secrets)
terraform.tfvars
*.auto.tfvars

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# OS files
.DS_Store
Thumbs.db
