# Copy this file to terraform.tfvars and adjust values.
# Do NOT commit terraform.tfvars to source control if it contains secrets.

aws_region          = "us-east-1"
server_name         = "linux-server"
environment         = "dev"
instance_type       = "t3.micro"
root_volume_size_gb = 20
assign_elastic_ip   = false

# Restrict SSH to your IP for better security, e.g. ["203.0.113.0/32"]
allowed_ssh_cidr    = ["0.0.0.0/0"]

# Set to the path of your local SSH public key to create a key pair, e.g.:
# public_key_path = "~/.ssh/id_rsa.pub"
public_key_path     = ""
